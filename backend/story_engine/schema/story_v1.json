{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StoryPack v1",
  "type": "object",
  "required": ["id", "title", "npcs", "scenes", "start_scene_id"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "language": { "type": "string" },
    "nsfw_allowed": { "type": "boolean" },
    "start_scene_id": { "type": "string" },
    "npcs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "traits": { "type": "array", "items": { "type": "string" } },
          "backstory": { "type": "string" },
          "avatar_url": { "type": "string" }
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["text", "choice", "event"] },
          "title": { "type": "string" },
          "speaker": { "type": "string" },
          "text": { "type": "string" },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "text"],
              "properties": {
                "id": { "type": "string" },
                "text": { "type": "string" },
                "next_scene_id": { "type": "string" }
              }
            }
          },
          "meta": { "type": "object" }
        }
      }
    }
  }
}

